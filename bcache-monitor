def refresh_device_selection(state):
    resolution = resolve_bcache_device(state.config.get("bcache_device", ""))
    state.device_name = resolution["device"]
    state.device_path = resolution["path"]
    state.device_source = resolution["source"]
    state.available_devices = resolution["devices"]
    state.device_warning = resolution["warning"]
    global BCACHE
    BCACHE = state.device_path


def handle_keypress(key, state):
    if key in [ord('q'), ord('Q')]:
        return "quit"
    if key in [ord('s'), ord('S')]:
        return "settings"
    if key in [ord('r'), ord('R')]:
        state.docker_last = 0.0
        return "reload"
    return "none"

