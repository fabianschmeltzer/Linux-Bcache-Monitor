def draw_line_graph(stdscr, data, y, x, w, h, color, maxv):
    if len(data) < 2 or w < 2 or h < 2:
        return

    d = list(data)[-w:]
    points = []
    for i, val in enumerate(d):
        row = y + h - 1 - int((max(0, val) / maxv) * (h - 1))
        row = max(y, min(y + h - 1, row))
        points.append((row, x + i))

    prev_row, prev_col = points[0]
    safe_addstr(stdscr, prev_row, prev_col, "•", color)

    for row, col in points[1:]:
        safe_addstr(stdscr, row, col, "•", color)
        if row == prev_row:
            for c in range(min(prev_col, col) + 1, max(prev_col, col)):
                safe_addstr(stdscr, row, c, "─", color)
        else:
            step = 1 if row > prev_row else -1
            cur = prev_row
            while cur != row:
                cur += step
                safe_addstr(stdscr, cur, prev_col, "│", color)
        prev_row, prev_col = row, col

def draw_y_markers(stdscr, y, x, h, maxv):
    ticks = [
        (0, maxv),
        (h // 2, maxv / 2),
        (h - 1, 0),
    ]
    for off, value in ticks:
        r = y + off
        safe_addstr(stdscr, r, x, "┤", 4)
        safe_addstr(stdscr, r, x - 7, f"{int(value):>6}", 4)

def pct_change(current, baseline):
    if baseline <= 0:
        return 0.0
    return ((current - baseline) / baseline) * 100.0

def trend_arrow(current, baseline):
    if baseline <= 0 and current > 0:
        return "↑"
    if baseline <= 0:
        return "→"
    if current > baseline:
        return "↑"
    if current < baseline:
        return "↓"
    return "→"

