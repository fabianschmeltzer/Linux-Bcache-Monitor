def draw_settings(stdscr, state):
    running, ps_state = list_running_containers()
    choices = sorted(set(running) | set(state.selected_containers))
    selected = set(state.selected_containers)
    device_choices = list(state.available_devices)
    selected_device = state.config.get("bcache_device", "").strip()
    idx = 0
    dev_idx = device_choices.index(selected_device) if selected_device in device_choices else 0
    device_scroll = 0
    container_scroll = 0
    mode = "containers"
    while True:
        stdscr.erase()
        my, mx = stdscr.getmaxyx()
        margin_y, margin_x = 1, 1
        box_w = max(10, mx - (margin_x * 2))
        box_h = max(10, my - (margin_y * 2))
        box_x = max(0, (mx - box_w) // 2)
        box_y = max(0, (my - box_h) // 2)
        inner_x = box_x + 2
        inner_w = max(1, box_w - 4)
        bottom_limit = box_y + box_h - 2

        stdscr.attron(curses.color_pair(4)); stdscr.border(); stdscr.attroff(curses.color_pair(4))
        for x in range(box_x, box_x + box_w):
            safe_addstr(stdscr, box_y, x, "─", 4); safe_addstr(stdscr, box_y + box_h - 1, x, "─", 4)
        for y in range(box_y, box_y + box_h):
            safe_addstr(stdscr, y, box_x, "│", 4); safe_addstr(stdscr, y, box_x + box_w - 1, "│", 4)
        safe_addstr(stdscr, box_y, box_x, "┌", 4); safe_addstr(stdscr, box_y, box_x + box_w - 1, "┐", 4)
        safe_addstr(stdscr, box_y + box_h - 1, box_x, "└", 4); safe_addstr(stdscr, box_y + box_h - 1, box_x + box_w - 1, "┘", 4)

        header_lines = ["SETTINGS"]
        header_lines += textwrap.wrap("↑↓ Navigation | Tab Bereich | Space Auswahl | Enter Speichern | Esc Zurück", width=inner_w)[:2]
        header_lines += textwrap.wrap(f"docker ps: {ps_state}", width=inner_w)[:1]
        header_lines += textwrap.wrap("Leere Auswahl = ALLE Container anzeigen", width=inner_w)[:1]

        cur_y = box_y + 1
        for i, line in enumerate(header_lines):
            if cur_y > bottom_limit:
                break
            color = 4 if i == 0 or line.startswith("docker ps:") else 3
            safe_addstr(stdscr, cur_y, inner_x, line[:inner_w], color)
            cur_y += 1

        if cur_y <= bottom_limit:
            safe_addstr(stdscr, cur_y, inner_x, "Device (Single-Select):"[:inner_w], 4 if mode == "device" else 0)
            cur_y += 1

        remaining_rows = max(0, bottom_limit - cur_y + 1)
        device_rows = max(1, remaining_rows // 3) if remaining_rows else 0
        container_label_y = cur_y + device_rows
        if container_label_y <= bottom_limit:
            safe_addstr(stdscr, container_label_y, inner_x, "Container (Multi-Select):"[:inner_w], 4 if mode == "containers" else 0)
        container_start_y = container_label_y + 1
        container_rows = max(0, bottom_limit - container_start_y + 1)

        if device_choices:
            dev_idx = max(0, min(dev_idx, len(device_choices) - 1))
            device_scroll = min(device_scroll, max(0, len(device_choices) - max(1, device_rows)))
            if dev_idx < device_scroll:
                device_scroll = dev_idx
            elif device_rows > 0 and dev_idx >= device_scroll + device_rows:
                device_scroll = dev_idx - device_rows + 1
            visible_devices = device_choices[device_scroll:device_scroll + max(0, device_rows)]
            for line_no, name in enumerate(visible_devices):
                y = cur_y + line_no
                if y > bottom_limit:
                    break
                abs_i = device_scroll + line_no
                marker = "(*)" if name == selected_device else "( )"
                prefix = ">" if mode == "device" and abs_i == dev_idx else " "
                safe_addstr(stdscr, y, inner_x, f"{prefix} {marker} {name}"[:inner_w], 2 if mode == "device" and abs_i == dev_idx else 0)
        elif cur_y <= bottom_limit:
            safe_addstr(stdscr, cur_y, inner_x, "Keine bcache-Devices gefunden."[:inner_w], 1)

        if choices and container_rows > 0:
            idx = max(0, min(idx, len(choices) - 1))
            container_scroll = min(container_scroll, max(0, len(choices) - container_rows))
            if idx < container_scroll:
                container_scroll = idx
            elif idx >= container_scroll + container_rows:
                container_scroll = idx - container_rows + 1
            visible_choices = choices[container_scroll:container_scroll + container_rows]
            for line_no, name in enumerate(visible_choices):
                y = container_start_y + line_no
                if y > bottom_limit:
                    break
                abs_i = container_scroll + line_no
                marker = "[x]" if name in selected else "[ ]"
                prefix = ">" if mode == "containers" and abs_i == idx else " "
                safe_addstr(stdscr, y, inner_x, f"{prefix} {marker} {name}"[:inner_w], 2 if mode == "containers" and abs_i == idx else 0)
        elif container_start_y <= bottom_limit:
            safe_addstr(stdscr, container_start_y, inner_x, "Keine Container gefunden."[:inner_w], 1)

        stdscr.refresh()
        ch = stdscr.getch()
        if ch in [27, ord("q"), ord("Q")]: return
        if ch == 9: mode = "device" if mode == "containers" else "containers"
        elif ch in [curses.KEY_UP, ord("k")] and mode == "containers" and choices: idx = (idx - 1) % len(choices)
        elif ch in [curses.KEY_DOWN, ord("j")] and mode == "containers" and choices: idx = (idx + 1) % len(choices)
        elif ch in [curses.KEY_UP, ord("k")] and mode == "device" and device_choices: dev_idx = (dev_idx - 1) % len(device_choices)
        elif ch in [curses.KEY_DOWN, ord("j")] and mode == "device" and device_choices: dev_idx = (dev_idx + 1) % len(device_choices)
        elif ch == ord(" ") and mode == "containers" and choices:
            name = choices[idx]; selected.remove(name) if name in selected else selected.add(name)
        elif ch == ord(" ") and mode == "device" and device_choices: selected_device = device_choices[dev_idx]
        elif ch in [ord("a"), ord("A")] and mode == "containers": selected = set() if selected else set(choices)
        elif ch in [10, 13]:
            state.selected_containers = sorted(selected)
            state.config["containers"] = state.selected_containers
            state.config["bcache_device"] = selected_device
            ok, msg = save_config(state.config)
            state.config_notice = "Config gespeichert." if ok else f"Config speichern fehlgeschlagen: {msg}"
            refresh_device_selection(state)
            return


def draw_main(stdscr):
    curses.curs_set(0)
    stdscr.nodelay(True)

    update_notice = ""
    updated_from = os.environ.get("BCACHE_MONITOR_UPDATED_FROM", "").strip()
    updated_to = os.environ.get("BCACHE_MONITOR_UPDATED_TO", "").strip()
    if updated_from and updated_to:
        update_notice = f"UPDATED: {updated_from} -> {updated_to}"

    ph,pm=stats()
    if ph is None or pm is None:
        ph, pm = 0, 0
    config, config_notice = load_config()
    state = AppState(config=config, config_notice=config_notice, update_notice=update_notice, selected_containers=list(config.get("containers", [])), ph=ph, pm=pm, pt=time.time())
    refresh_device_selection(state)

    while True:
        stdscr.erase()
        maxy,maxx=stdscr.getmaxyx()

        refresh_device_selection(state)
        if not state.device_path:
            safe_addstr(stdscr, 0, 0, "No bcache device found (set BCACHE_MONITOR_DEVICE)", 1)
            if state.available_devices:
                safe_addstr(stdscr, 1, 0, f"Available: {', '.join(state.available_devices)}", 3)
            safe_addstr(stdscr, 2, 0, "Q=quit")
            stdscr.refresh()
            if stdscr.getch() in [ord('q'),ord('Q')]:
                break
            time.sleep(1)
            continue

        compact_mode = maxy < 26 or maxx < 100

        # DATA
        if not state.device_path:
            safe_addstr(stdscr,0,1,f"BCACHE OBSERVABILITY v{__version__}",4)
            safe_addstr(stdscr,2,1,"ERROR: Kein bcache-Gerät verfügbar.",1)
            safe_addstr(stdscr,3,1,"Erwartet wird ein Pfad wie /sys/block/<device>/bcache.",3)
            safe_addstr(stdscr,4,1,"Bitte prüfen, ob bcache aktiv ist und das Device eingebunden wurde.",3)
            safe_addstr(stdscr,maxy-1,1,"Q=quit")
            stdscr.refresh()
            if stdscr.getch() in [ord('q'),ord('Q')]:
                break
            time.sleep(1)
            continue

        h0,m0=stats()
        sysfs_ok = not (h0 is None or m0 is None)
        if not sysfs_ok:
            h0, m0 = state.ph, state.pm
        now=time.time()
        dt=max(now-state.pt,0.5)

        hps=int((h0-state.ph)/dt); mps=int((m0-state.pm)/dt)
        state.ph,state.pm,state.pt=h0,m0,now
        state.hits.append(hps); state.miss.append(mps); state.miss_trend.append(mps)

        eff=h0/(h0+m0)*100 if (h0+m0) else 0
        dirty_bytes=dirty_val()
        dirty_display=format_dirty_value(dirty_bytes)

        # -------- HEADER --------
        safe_addstr(stdscr,0,1,f"HEADER | BCACHE OBSERVABILITY v{__version__} | DEVICE {state.device_name or 'N/A'}",4)

        # -------- KPI BLOCK --------
        ratio = (mps / hps) if hps > 0 else (float("inf") if mps > 0 else 0.0)
        ratio_text = "∞" if ratio == float("inf") else f"{ratio:.2f}"
        safe_addstr(stdscr,2,1,f"KPI   | EFF {eff:.1f}%   DIRTY {dirty_display}   MISS/HIT {ratio_text}")
        safe_addstr(stdscr,3,1,f"KPI   | LIVE HIT/s {hps}   MISS/s {mps}   SRC {state.device_source}")

        # -------- GRAPH --------
        graph_h = 5 if compact_mode else max(8, maxy//3)
        graph_y = 5
        graph_x = 8
        available_graph_w = maxx - graph_x
        graph_w = max(1, available_graph_w)
        if available_graph_w >= 20:
            graph_w = max(20, graph_w)
        raw_maxv = max(max(state.hits) if state.hits else 0, max(state.miss) if state.miss else 0, 1)
        target_maxv = FIXED_MAX_PS if FIXED_MAX_PS > 0 else raw_maxv
        state.graph_scale = 0.35 * target_maxv + 0.65 * state.graph_scale
        maxv = max(int(state.graph_scale), 1)

        draw_y_markers(stdscr, graph_y, graph_x - 1, graph_h, maxv)
        draw_line_graph(stdscr, state.miss, graph_y, graph_x, graph_w, graph_h, 1, maxv)
        draw_line_graph(stdscr, state.hits, graph_y, graph_x, graph_w, graph_h, 2, maxv)
        safe_addstr(stdscr, graph_y + graph_h, graph_x, "└" + ("─" * (graph_w - 1)), 4)
        safe_addstr(stdscr, graph_y - 1, graph_x, "GRAPH | M=red MISS/s | H=green HIT/s", 4)
        scale_col = graph_x + 34
        if scale_col < maxx:
            safe_addstr(stdscr, graph_y - 1, scale_col, f"Scale {maxv}/s", 4)

        avg_h = (sum(state.hits) / len(state.hits)) if state.hits else 0
        avg_m = (sum(state.miss) / len(state.miss)) if state.miss else 0
        max_h = max(state.hits) if state.hits else 0
        max_m = max(state.miss) if state.miss else 0
        safe_addstr(stdscr, graph_y, graph_x + 2, f"H {hps}/{avg_h:.0f}/{max_h}", 2)
        safe_addstr(stdscr, graph_y + 1, graph_x + 2, f"M {mps}/{avg_m:.0f}/{max_m}", 1)
        safe_addstr(stdscr, graph_y + graph_h + 1, graph_x, f"window {min(len(state.hits), graph_w)}s (buffer {HISTORY}s)", 4)

        # -------- STATUS --------
        status,color,reason=status_from_metrics(eff,hps,mps,state.miss_trend)
        safe_addstr(stdscr,4+graph_h+1,1,f"HEALTH | PRIMARY ALERT: {status} ({reason})",color)
        eff_arrow = trend_arrow(eff, avg_h and (h0/(h0+m0)*100 if (h0+m0) else eff))
        ratio_arrow = trend_arrow(mps, avg_m)
        safe_addstr(stdscr,4+graph_h+2,1,f"HEALTH | EFF {eff:.1f}%{eff_arrow} (crit<{EFF_CRITICAL_THRESHOLD:.0f}) | MISS/HIT {ratio_text}{ratio_arrow} (crit≥{MISS_HIT_RATIO_CRITICAL:.2f})", color)
        if len(state.hits) >= 10 and len(state.miss) >= 10:
            short_h = sum(list(state.hits)[-10:]) / 10
            short_m = sum(list(state.miss)[-10:]) / 10
        else:
            short_h = avg_h
            short_m = avg_m
        safe_addstr(stdscr,graph_y+graph_h+3,1,f"10s AVG -> H:{short_h:.0f}/s  M:{short_m:.0f}/s  ΔMISS:{pct_change(short_m, avg_m):+.0f}% vs window",4)

        if compact_mode:
            safe_addstr(stdscr, graph_y + graph_h + 5, 1, "COMPACT MODE | Kernmetriken aktiv", 3)
            if state.update_notice: safe_addstr(stdscr,maxy-2,1,state.update_notice,3)
            if state.config_notice: safe_addstr(stdscr,maxy-2,1,state.config_notice,3)
            elif state.device_warning: safe_addstr(stdscr,maxy-2,1,state.device_warning,3)
            safe_addstr(stdscr,maxy-1,1,"FOOTER/HOTKEYS | Q quit | S settings | R reload",4)
            stdscr.refresh()
            action = handle_keypress(stdscr.getch(), state)
            if action == "quit": break
            if action == "settings": draw_settings(stdscr, state)
            time.sleep(1)
            continue

        # -------- CONTAINERS --------
        y = graph_y+graph_h+5
        safe_addstr(stdscr,y,1,"CONTAINERS | CACHE NUMBERS",4)
        y += 1
        safe_addstr(stdscr,y,1,f"Total Hits:   {h0:,}")
        safe_addstr(stdscr,y,32,f"Total Misses: {m0:,}")
        y += 1
        safe_addstr(stdscr,y,1,f"Efficiency:   {eff:6.2f}%")
        safe_addstr(stdscr,y,32,f"Miss/Hit:     {ratio_text}")
        y += 1
        safe_addstr(stdscr,y,1,f"Peak Hit/s:   {max_h:>6}")
        safe_addstr(stdscr,y,32,f"Peak Miss/s:  {max_m:>6}")
        y += 2
        safe_addstr(stdscr,y,1,"CONTAINERS",4)
        y+=1

        if now - state.docker_last >= DOCKER_REFRESH_SECONDS:
            state.docker_cache, state.docker_state = list_container_stats(state.selected_containers)
            state.docker_last = now

        selection_label = f"{len(state.selected_containers)} selected" if state.selected_containers else "ALL (empty selection)"
        safe_addstr(stdscr, y, 1, f"Containers: {selection_label}", 4)
        y += 1
        safe_addstr(stdscr,y,32,f"DATA: SYSFS {'OK' if sysfs_ok else 'MISSING'} | DOCKER {state.docker_state}", 4)
        y += 1
        table_start_x = 1
        table_usable_w = max(1, maxx - table_start_x)
        min_name_col_w = 8
        min_cpu_col_w = 10
        min_mem_col_w = 10
        min_total_w = min_name_col_w + min_cpu_col_w + min_mem_col_w

        if table_usable_w <= min_total_w:
            # Deterministisch schrumpfen: zuerst Name, dann CPU, dann RAM.
            name_col_w = min_name_col_w
            cpu_col_w = min_cpu_col_w
            mem_col_w = min_mem_col_w
            overflow = min_total_w - table_usable_w

            shrink = min(overflow, max(0, name_col_w - 1))
            name_col_w -= shrink
            overflow -= shrink
            shrink = min(overflow, max(0, cpu_col_w - 1))
            cpu_col_w -= shrink
            overflow -= shrink
            shrink = min(overflow, max(0, mem_col_w - 1))
            mem_col_w -= shrink
        else:
            # Erst Mindestbreiten, Restbreite bevorzugt an Name verteilen.
            rest_w = table_usable_w - min_total_w
            name_extra = int(rest_w * 0.70)
            cpu_extra = int(rest_w * 0.15)
            mem_extra = int(rest_w * 0.15)
            used_extra = name_extra + cpu_extra + mem_extra
            name_extra += (rest_w - used_extra)

            name_col_w = min_name_col_w + name_extra
            cpu_col_w = min_cpu_col_w + cpu_extra
            mem_col_w = min_mem_col_w + mem_extra

        # Sicherheitsnetz: Summe darf nie größer als nutzbare Tabellenbreite sein.
        total_col_w = name_col_w + cpu_col_w + mem_col_w
        if total_col_w > table_usable_w:
            reduce_by = total_col_w - table_usable_w
            name_shrink = min(reduce_by, max(0, name_col_w - 1))
            name_col_w -= name_shrink
            reduce_by -= name_shrink
            cpu_shrink = min(reduce_by, max(0, cpu_col_w - 1))
            cpu_col_w -= cpu_shrink
            reduce_by -= cpu_shrink
            mem_col_w -= min(reduce_by, max(0, mem_col_w - 1))

        cpu_x = table_start_x + name_col_w
        mem_x = cpu_x + cpu_col_w
        safe_addstr(stdscr, y, table_start_x, f"{'NAME':<{name_col_w-1}}{'CPU':>{cpu_col_w}}{'RAM':>{mem_col_w}}", 4)
        y += 1
        for name,cpu,mem in state.docker_cache:
            if y+1 >= maxy:
                break
            cpu_room = max(0, cpu_col_w - 10)
            mem_room = max(0, mem_col_w - 10)
            bar_cpu = "█" * (int((max(0.0, min(cpu, 100.0)) / 100) * cpu_room) if cpu_room else 0)
            bar_mem = "█" * (int((max(0.0, min(mem, 100.0)) / 100) * mem_room) if mem_room else 0)

            max_name_len = max(6, name_col_w - 2)
            disp_name = name if len(name) <= max_name_len else name[:max_name_len-1] + "…"
            safe_addstr(stdscr,y,table_start_x,f"{disp_name:<{name_col_w-1}}")
            safe_addstr(stdscr,y,cpu_x,f"C {cpu:5.1f}% {bar_cpu:<{cpu_room}}",2)
            safe_addstr(stdscr,y,mem_x,f"R {mem:5.1f}% {bar_mem:<{mem_room}}",3)

            y+=1

        if state.update_notice: safe_addstr(stdscr,maxy-2,1,state.update_notice,3)
        if state.config_notice: safe_addstr(stdscr,maxy-2,1,state.config_notice,3)
        elif state.device_warning: safe_addstr(stdscr,maxy-2,1,state.device_warning,3)
        safe_addstr(stdscr,maxy-1,1,"FOOTER/HOTKEYS | Q quit | S settings | R reload",4)

        stdscr.refresh()

        action = handle_keypress(stdscr.getch(), state)
        if action == "quit": break
        if action == "settings": draw_settings(stdscr, state)

        time.sleep(1)

def main():
    updated_from = os.environ.get("BCACHE_MONITOR_UPDATED_FROM")
    updated_to = os.environ.get("BCACHE_MONITOR_UPDATED_TO")
    if updated_from and updated_to:
        print_update_event(f"Update erfolgreich angewendet: {updated_from} -> {updated_to}")
        time.sleep(1)

    self_update_if_needed()
    curses.wrapper(init)

def init(stdscr):
    curses.start_color()
    curses.init_pair(1,curses.COLOR_RED,curses.COLOR_BLACK)
    curses.init_pair(2,curses.COLOR_GREEN,curses.COLOR_BLACK)
    curses.init_pair(3,curses.COLOR_YELLOW,curses.COLOR_BLACK)
    curses.init_pair(4,curses.COLOR_CYAN,curses.COLOR_BLACK)
    draw_main(stdscr)

if __name__=="__main__":
    main()
