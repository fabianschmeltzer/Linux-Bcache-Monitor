def safe_addstr(stdscr,y,x,text,color=0):
    maxy,maxx = stdscr.getmaxyx()
    if 0 <= y < maxy and 0 <= x < maxx:
        try:
            available = maxx - x
            if available > 0:
                stdscr.addstr(y,x,text[:available],curses.color_pair(color))
        except:
            pass

