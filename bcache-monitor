#!/usr/bin/env python3
import curses, time, subprocess, os, sys, urllib.request, glob, json
from collections import deque

__version__ = "0.3.5"

# URLs can be overridden for your publish target, e.g. GitHub raw links.
VERSION_URL = os.environ.get("BCACHE_MONITOR_VERSION_URL", "https://raw.githubusercontent.com/fabianschmeltzer/Linux-Bcache-Monitor/main/VERSION")
SCRIPT_URL = os.environ.get("BCACHE_MONITOR_SCRIPT_URL", "https://raw.githubusercontent.com/fabianschmeltzer/Linux-Bcache-Monitor/main/bcache-monitor")
BCACHE_ENV_DEVICE = os.environ.get("BCACHE_MONITOR_DEVICE", "").strip()
FIXED_MAX_PS = int(os.environ.get("BCACHE_MONITOR_MAX_PS", "0") or 0)
DOCKER_REFRESH_SECONDS = float(os.environ.get("BCACHE_MONITOR_DOCKER_REFRESH_SECONDS", "4"))
HISTORY=240
TREND_WINDOW=30
EFF_WARN_THRESHOLD=70.0
EFF_CRITICAL_THRESHOLD=50.0
MISS_HIT_RATIO_WARN=0.75
MISS_HIT_RATIO_CRITICAL=1.10
MISS_TREND_WARN=1.20
MISS_TREND_CRITICAL=1.50

MIN_SCRIPT_SIZE_BYTES = 1024
MAX_SCRIPT_SIZE_BYTES = 512 * 1024

def is_valid_version_string(value):
    if not value:
        return False
    parts = value.strip().split('.')
    if not parts:
        return False
    return all(part.isdigit() for part in parts)


DEFAULT_CONFIG = {
    "containers": [
        "nextcloud_app",
        "immich-server",
        "immich-machine-learning",
        "piwigo",
    ],
    "bcache_device": "",
}
CONFIG_PATH = os.path.expanduser("~/.config/bcache-monitor/config.json")

def discover_bcache_device():
    candidates = sorted(glob.glob("/sys/block/*/bcache"))
    if not candidates:
        return None, []
    devices = [os.path.basename(os.path.dirname(c)) for c in candidates]
    if BCACHE_ENV_DEVICE:
        if BCACHE_ENV_DEVICE in devices:
            return f"/sys/block/{BCACHE_ENV_DEVICE}/bcache", devices
        return None, devices
    return candidates[0], devices

BCACHE, BCACHE_DEVICES = discover_bcache_device()
ACTIVE_DEVICE = os.path.basename(os.path.dirname(BCACHE)) if BCACHE else "N/A"

# ---------- SAFE DRAW ----------

def safe_addstr(stdscr,y,x,text,color=0):
    maxy,maxx = stdscr.getmaxyx()
    if 0 <= y < maxy and 0 <= x < maxx:
        try:
            stdscr.addstr(y,x,text[:maxx-x-1],curses.color_pair(color))
        except:
            pass

# ---------- HELPERS ----------

def read(p):
    try:
        return open(p).read().strip()
    except (FileNotFoundError, PermissionError, OSError):
        return None

def parse_version(v):
    try:
        return tuple(int(part) for part in v.strip().split("."))
    except:
        return (0,)

def read_remote_text(url):
    if not url:
        return ""
    try:
        with urllib.request.urlopen(url, timeout=3) as r:
            return r.read().decode("utf-8").strip()
    except:
        return ""

def read_remote_bytes(url):
    if not url:
        return b""
    try:
        with urllib.request.urlopen(url, timeout=3) as r:
            return r.read()
    except:
        return b""

def print_update_event(message):
    ts = time.strftime("%H:%M:%S")
    print(f"[bcache-monitor][{ts}] {message}", flush=True)

def self_update_if_needed():
    remote_version = read_remote_text(VERSION_URL)
    if not is_valid_version_string(remote_version):
        return False

    if parse_version(remote_version) <= parse_version(__version__):
        return False

    print_update_event(f"Update verfügbar: {__version__} -> {remote_version}")

    script_bytes = read_remote_bytes(SCRIPT_URL)
    if not script_bytes:
        print_update_event("Update abgebrochen: Script konnte nicht geladen werden")
        return False

    script_content = script_bytes.decode("utf-8", errors="replace")
    if not script_content.startswith("#!/usr/bin/env python3"):
        return False

    script_size = len(script_bytes)
    if script_size < MIN_SCRIPT_SIZE_BYTES or script_size > MAX_SCRIPT_SIZE_BYTES:
        print_update_event("Update abgebrochen: ungültige Scriptgröße")
        return False

    script_path = os.path.realpath(__file__)
    temp_path = f"{script_path}.tmp"

    try:
        current_mode = os.stat(script_path).st_mode & 0o777

        with open(temp_path, "w", encoding="utf-8") as dst:
            dst.write(script_content)
            dst.flush()
            os.fsync(dst.fileno())

        os.chmod(temp_path, current_mode)
        os.replace(temp_path, script_path)

        os.environ["BCACHE_MONITOR_UPDATED_FROM"] = __version__
        os.environ["BCACHE_MONITOR_UPDATED_TO"] = remote_version
        print_update_event(f"Aktualisiere auf {remote_version} und starte neu...")
        time.sleep(1)
        os.execv(script_path, [script_path] + sys.argv[1:])
    except Exception as exc:
        print_update_event(f"Update fehlgeschlagen: {exc}")
    finally:
        try:
            if os.path.exists(temp_path):
                os.remove(temp_path)
        except:
            pass

    return False

def parse_sysfs_size_bytes(raw_value):
    if raw_value is None:
        return None

    token = str(raw_value).strip()
    if not token:
        return None

    token = token.replace(" ", "")
    lower = token.lower()

    i = 0
    while i < len(lower) and (lower[i].isdigit() or lower[i] == "."):
        i += 1

    if i == 0:
        return None

    number = lower[:i]
    suffix = lower[i:]

    try:
        value = float(number)
    except:
        return None

    units = {
        "": 1,
        "b": 1,
        "k": 1024,
        "kb": 1024,
        "kib": 1024,
        "m": 1024 ** 2,
        "mb": 1024 ** 2,
        "mib": 1024 ** 2,
        "g": 1024 ** 3,
        "gb": 1024 ** 3,
        "gib": 1024 ** 3,
    }

    if suffix not in units:
        return None

    return int(value * units[suffix])


def format_dirty_value(dirty_bytes):
    if dirty_bytes is None:
        return "N/A"

    mib = dirty_bytes / (1024 ** 2)
    if mib < 1024:
        return f"{mib:.1f} MiB"

    gib = dirty_bytes / (1024 ** 3)
    return f"{gib:.1f} GiB"


def dirty_val():
    if not BCACHE:
        return None
    return parse_sysfs_size_bytes(read(f"{BCACHE}/dirty_data"))

def discover_bcache_device():
    candidates = []
    for path in sorted(glob.glob("/sys/block/*/bcache")):
        if os.path.isdir(path):
            device = os.path.basename(os.path.dirname(path))
            if device:
                candidates.append((device, path))

    if not candidates:
        return None, None, "Kein bcache-Gerät gefunden (erwartet: /sys/block/*/bcache)."

    if len(candidates) == 1:
        device, path = candidates[0]
        return device, path, ""

    requested_device = os.environ.get("BCACHE_MONITOR_DEVICE", "").strip()
    if requested_device:
        for device, path in candidates:
            if device == requested_device:
                return device, path, ""

    device, path = candidates[0]
    hint = "Mehrere bcache-Geräte gefunden; nutze BCACHE_MONITOR_DEVICE=<name> für Auswahl."
    return device, path, hint


def default_config():
    return {
        "containers": list(DEFAULT_CONFIG["containers"]),
        "bcache_device": DEFAULT_CONFIG["bcache_device"],
    }


def _sanitize_config(raw):
    cfg = default_config()
    if not isinstance(raw, dict):
        return cfg

    containers = raw.get("containers")
    if isinstance(containers, list):
        cleaned = []
        seen = set()
        for item in containers:
            if not isinstance(item, str):
                continue
            name = item.strip()
            if not name or name in seen:
                continue
            seen.add(name)
            cleaned.append(name)
        cfg["containers"] = cleaned

    dev = raw.get("bcache_device")
    if isinstance(dev, str):
        cfg["bcache_device"] = dev.strip()

    return cfg


def load_config():
    try:
        with open(CONFIG_PATH, "r", encoding="utf-8") as src:
            return _sanitize_config(json.load(src)), ""
    except FileNotFoundError:
        cfg = default_config()
        ok, msg = save_config(cfg)
        return cfg, ("Config nicht gefunden; Defaults erstellt." if ok else f"Config fehlt ({msg})")
    except PermissionError:
        return default_config(), "Config nicht lesbar (Berechtigungen)."
    except json.JSONDecodeError:
        return default_config(), "Config defekt (JSON). Defaults genutzt."
    except OSError as exc:
        return default_config(), f"Config-Lesen fehlgeschlagen: {exc}"


def save_config(config):
    cfg = _sanitize_config(config)
    directory = os.path.dirname(CONFIG_PATH)
    temp_path = f"{CONFIG_PATH}.tmp"
    try:
        os.makedirs(directory, exist_ok=True)
        with open(temp_path, "w", encoding="utf-8") as dst:
            json.dump(cfg, dst, indent=2, ensure_ascii=False)
            dst.write("\n")
            dst.flush()
            os.fsync(dst.fileno())
        os.replace(temp_path, CONFIG_PATH)
        return True, ""
    except PermissionError:
        return False, "Keine Schreibberechtigung für Config."
    except OSError as exc:
        return False, str(exc)
    finally:
        try:
            if os.path.exists(temp_path):
                os.remove(temp_path)
        except OSError:
            pass


def list_running_containers():
    try:
        cp = subprocess.run(
            ["docker", "ps", "--format", "{{.Names}}"],
            capture_output=True, text=True, timeout=2.0, check=False
        )
        if cp.returncode != 0:
            return [], f"ERR:{cp.returncode}"
        names = [line.strip() for line in cp.stdout.splitlines() if line.strip()]
        return names, "OK"
    except subprocess.TimeoutExpired:
        return [], "TIMEOUT"
    except FileNotFoundError:
        return [], "NOT INSTALLED"

def stats():
    for r,d,_ in os.walk("/sys/fs/bcache"):
        if "stats_total" in d:
            p=os.path.join(r,"stats_total")
            h = read(f"{p}/cache_hits")
            m = read(f"{p}/cache_misses")
            if h is None or m is None:
                return None, None
            return int(h), int(m)
    return None, None

def _parse_percent(raw):
    if raw is None:
        return None
    token = str(raw).strip().replace("%", "").replace(",", ".")
    if not token:
        return None
    try:
        return float(token)
    except ValueError:
        return None


def docker(selected_containers):
    try:
        cp = subprocess.run(
            ["docker", "stats", "--no-stream", "--format", "{{.Name}}|{{.CPUPerc}}|{{.MemPerc}}"],
            capture_output=True, text=True, timeout=2.0, check=False
        )
        if cp.returncode != 0:
            return [], f"ERR:{cp.returncode}"

        res = []
        for line in cp.stdout.splitlines():
            parts = line.split("|")
            if len(parts) != 3:
                continue
            name, cpu_raw, mem_raw = parts
            if selected_containers and name not in selected_containers:
                continue

            cpu = _parse_percent(cpu_raw)
            mem = _parse_percent(mem_raw)
            if cpu is None or mem is None:
                continue
            res.append((name, cpu, mem))

        if res:
            return res, "OK"

        # docker reachable, but none of the monitored containers currently running
        return [], ("NO CONTAINERS" if selected_containers else "ALL (none running)")
    except subprocess.TimeoutExpired:
        return [], "TIMEOUT"
    except FileNotFoundError:
        return [], "NOT INSTALLED"

# ---------- GRAPH (AREA STYLE) ----------



def status_from_metrics(eff, hps, mps, miss_window):
    ratio = (mps / hps) if hps > 0 else (float("inf") if mps > 0 else 0.0)

    trend = 1.0
    if len(miss_window) >= 6:
        half = len(miss_window) // 2
        first_avg = sum(list(miss_window)[:half]) / max(half, 1)
        second_avg = sum(list(miss_window)[half:]) / max(len(miss_window) - half, 1)
        if first_avg <= 0:
            trend = float("inf") if second_avg > 0 else 1.0
        else:
            trend = second_avg / first_avg

    status = "OK"
    color = 2
    reasons = []

    if eff < EFF_CRITICAL_THRESHOLD:
        status = "CRITICAL"
        color = 1
        reasons.append(f"eff {eff:.0f}%")
    elif eff < EFF_WARN_THRESHOLD:
        if status != "CRITICAL":
            status = "WARN"
            color = 3
        reasons.append(f"eff {eff:.0f}%")

    if ratio >= MISS_HIT_RATIO_CRITICAL:
        status = "CRITICAL"
        color = 1
        reasons.append(f"miss/hit {ratio:.2f}")
    elif ratio >= MISS_HIT_RATIO_WARN and status == "OK":
        status = "WARN"
        color = 3
        reasons.append(f"miss/hit {ratio:.2f}")

    if trend >= MISS_TREND_CRITICAL:
        status = "CRITICAL"
        color = 1
        reasons.append("miss trend ↑")
    elif trend >= MISS_TREND_WARN and status == "OK":
        status = "WARN"
        color = 3
        reasons.append("miss trend ↑")

    if not reasons:
        reasons.append("stable")

    return status, color, ", ".join(reasons)
def draw_area_graph(stdscr,data,y,x,w,h,color):
    if len(data)<2: return
    d=list(data)[-w:]
    maxv=max(d) if max(d)>0 else 1

    for i,val in enumerate(d):
        height=int((val/maxv)*(h-1))
        for j in range(height):
            safe_addstr(stdscr,y+h-j,x+i,"█",color)
# ---------- GRAPH ----------

def draw_line_graph(stdscr, data, y, x, w, h, color, maxv):
    if len(data) < 2 or w < 2 or h < 2:
        return

    d = list(data)[-w:]
    points = []
    for i, val in enumerate(d):
        row = y + h - 1 - int((max(0, val) / maxv) * (h - 1))
        row = max(y, min(y + h - 1, row))
        points.append((row, x + i))

    prev_row, prev_col = points[0]
    safe_addstr(stdscr, prev_row, prev_col, "•", color)

    for row, col in points[1:]:
        safe_addstr(stdscr, row, col, "•", color)
        if row == prev_row:
            for c in range(min(prev_col, col) + 1, max(prev_col, col)):
                safe_addstr(stdscr, row, c, "─", color)
        else:
            step = 1 if row > prev_row else -1
            cur = prev_row
            while cur != row:
                cur += step
                safe_addstr(stdscr, cur, prev_col, "│", color)
        prev_row, prev_col = row, col

def draw_y_markers(stdscr, y, x, h, maxv):
    ticks = [
        (0, maxv),
        (h // 2, maxv / 2),
        (h - 1, 0),
    ]
    for off, value in ticks:
        r = y + off
        safe_addstr(stdscr, r, x, "┤", 4)
        safe_addstr(stdscr, r, x - 7, f"{int(value):>6}", 4)

def pct_change(current, baseline):
    if baseline <= 0:
        return 0.0
    return ((current - baseline) / baseline) * 100.0

def trend_arrow(current, baseline):
    if baseline <= 0 and current > 0:
        return "↑"
    if baseline <= 0:
        return "→"
    if current > baseline:
        return "↑"
    if current < baseline:
        return "↓"
    return "→"

# ---------- MAIN ----------

def draw(stdscr):
    curses.curs_set(0)
    stdscr.nodelay(True)

    update_notice = ""
    updated_from = os.environ.get("BCACHE_MONITOR_UPDATED_FROM", "").strip()
    updated_to = os.environ.get("BCACHE_MONITOR_UPDATED_TO", "").strip()
    if updated_from and updated_to:
        update_notice = f"UPDATED: {updated_from} -> {updated_to}"

    hits=deque(maxlen=HISTORY)
    miss=deque(maxlen=HISTORY)
    miss_trend=deque(maxlen=TREND_WINDOW)

    device_name, device_path, device_hint = discover_bcache_device()
    global BCACHE
    if device_path:
        BCACHE = device_path

    ph,pm=stats()
    if ph is None or pm is None:
        ph, pm = 0, 0
    pt=time.time()
    docker_cache = []
    docker_state = "UNAVAILABLE"
    docker_last = 0.0
    graph_scale = 1.0
    config, config_notice = load_config()
    selected_containers = list(config.get("containers", []))
    if config.get("bcache_device"):
        os.environ["BCACHE_MONITOR_DEVICE"] = config["bcache_device"]

    def open_settings():
        nonlocal selected_containers, config_notice
        running, state = list_running_containers()
        choices = sorted(set(running) | set(selected_containers))
        selected = set(selected_containers)
        idx = 0
        while True:
            stdscr.erase()
            my, mx = stdscr.getmaxyx()
            safe_addstr(stdscr, 0, 2, "SETTINGS: Container Auswahl", 4)
            safe_addstr(stdscr, 1, 2, "Space=toggle  Enter=speichern  A=alle/keine  Esc=zurück")
            safe_addstr(stdscr, 2, 2, f"docker ps: {state}", 4)
            safe_addstr(stdscr, 3, 2, "Leere Auswahl = ALLE Container anzeigen", 3)
            top = 5
            if not choices:
                safe_addstr(stdscr, top, 2, "Keine Container gefunden.", 1)
            for i, name in enumerate(choices):
                if top + i >= my - 2:
                    break
                marker = "[x]" if name in selected else "[ ]"
                prefix = ">" if i == idx else " "
                safe_addstr(stdscr, top + i, 2, f"{prefix} {marker} {name}", 2 if i == idx else 0)
            stdscr.refresh()
            ch = stdscr.getch()
            if ch in [27, ord("q"), ord("Q")]:
                return
            if ch in [curses.KEY_UP, ord("k")] and choices:
                idx = (idx - 1) % len(choices)
            elif ch in [curses.KEY_DOWN, ord("j")] and choices:
                idx = (idx + 1) % len(choices)
            elif ch == ord(" ") and choices:
                name = choices[idx]
                if name in selected:
                    selected.remove(name)
                else:
                    selected.add(name)
            elif ch in [ord("a"), ord("A")]:
                selected = set() if selected else set(choices)
            elif ch in [10, 13]:
                selected_containers = sorted(selected)
                config["containers"] = selected_containers
                ok, msg = save_config(config)
                config_notice = "Config gespeichert." if ok else f"Config speichern fehlgeschlagen: {msg}"
                return

    while True:
        stdscr.erase()
        maxy,maxx=stdscr.getmaxyx()

        if not BCACHE:
            safe_addstr(stdscr, 0, 0, "No bcache device found (set BCACHE_MONITOR_DEVICE)", 1)
            if BCACHE_DEVICES:
                safe_addstr(stdscr, 1, 0, f"Available: {', '.join(BCACHE_DEVICES)}", 3)
            safe_addstr(stdscr, 2, 0, "Q=quit")
            stdscr.refresh()
            if stdscr.getch() in [ord('q'),ord('Q')]:
                break
            time.sleep(1)
            continue

        if maxy < 12 or maxx < 48:
            safe_addstr(stdscr, 0, 0, "BCACHE OBS")
            safe_addstr(stdscr, 1, 0, "Terminal too small")
            safe_addstr(stdscr, 2, 0, f"H:{hps if 'hps' in locals() else 0} M:{mps if 'mps' in locals() else 0}")
            safe_addstr(stdscr, 3, 0, "Q=quit")
            stdscr.refresh()
            if stdscr.getch() in [ord('q'),ord('Q')]:
                break
            time.sleep(1)
            continue

        # DATA
        if not device_path:
            safe_addstr(stdscr,0,2,f"BCACHE OBSERVABILITY v{__version__}",4)
            safe_addstr(stdscr,2,2,"ERROR: Kein bcache-Gerät verfügbar.",1)
            safe_addstr(stdscr,3,2,"Erwartet wird ein Pfad wie /sys/block/<device>/bcache.",3)
            safe_addstr(stdscr,4,2,"Bitte prüfen, ob bcache aktiv ist und das Device eingebunden wurde.",3)
            safe_addstr(stdscr,maxy-1,2,"Q=quit")
            stdscr.refresh()
            if stdscr.getch() in [ord('q'),ord('Q')]:
                break
            time.sleep(1)
            continue

        h0,m0=stats()
        sysfs_ok = not (h0 is None or m0 is None)
        if not sysfs_ok:
            h0, m0 = ph, pm
        now=time.time()
        dt=max(now-pt,0.5)

        hps=int((h0-ph)/dt)
        mps=int((m0-pm)/dt)

        ph,pm,pt=h0,m0,now

        hits.append(hps)
        miss.append(mps)
        miss_trend.append(mps)

        eff=h0/(h0+m0)*100 if (h0+m0) else 0
        dirty_bytes=dirty_val()
        dirty_display=format_dirty_value(dirty_bytes)

        # -------- HEADER --------
        safe_addstr(stdscr,0,2,f"BCACHE OBSERVABILITY v{__version__} | DEVICE {device_name or ACTIVE_DEVICE}",4)

        # -------- TOP BAR --------
        ratio = (mps / hps) if hps > 0 else (float("inf") if mps > 0 else 0.0)
        ratio_text = "∞" if ratio == float("inf") else f"{ratio:.2f}"
        safe_addstr(stdscr,2,2,f"EFF {eff:.1f}%   DIRTY {dirty_display}   MISS/HIT {ratio_text}")
        safe_addstr(stdscr,3,2,f"LIVE: HIT/s {hps}   MISS/s {mps}   DEVICE {device_name or ACTIVE_DEVICE}")

        # -------- GRAPH --------
        graph_h = max(8, maxy//3)
        graph_w = max(20, maxx-14)
        graph_y = 5
        graph_x = 10
        raw_maxv = max(max(hits) if hits else 0, max(miss) if miss else 0, 1)
        target_maxv = FIXED_MAX_PS if FIXED_MAX_PS > 0 else raw_maxv
        graph_scale = 0.35 * target_maxv + 0.65 * graph_scale
        maxv = max(int(graph_scale), 1)

        draw_y_markers(stdscr, graph_y, graph_x - 1, graph_h, maxv)
        draw_line_graph(stdscr, miss, graph_y, graph_x, graph_w, graph_h, 1, maxv)
        draw_line_graph(stdscr, hits, graph_y, graph_x, graph_w, graph_h, 2, maxv)
        safe_addstr(stdscr, graph_y + graph_h, graph_x, "└" + ("─" * (graph_w - 1)), 4)
        safe_addstr(stdscr, graph_y - 1, graph_x, "M=red MISS/s | H=green HIT/s", 4)
        safe_addstr(stdscr, graph_y - 1, graph_x + 34, f"Scale {maxv}/s", 4)

        avg_h = (sum(hits) / len(hits)) if hits else 0
        avg_m = (sum(miss) / len(miss)) if miss else 0
        max_h = max(hits) if hits else 0
        max_m = max(miss) if miss else 0
        safe_addstr(stdscr, graph_y, graph_x + 2, f"H {hps}/{avg_h:.0f}/{max_h}", 2)
        safe_addstr(stdscr, graph_y + 1, graph_x + 2, f"M {mps}/{avg_m:.0f}/{max_m}", 1)
        safe_addstr(stdscr, graph_y + graph_h + 1, graph_x, f"window {min(len(hits), graph_w)}s (buffer {HISTORY}s)", 4)

        # -------- STATUS --------
        status,color,reason=status_from_metrics(eff,hps,mps,miss_trend)
        safe_addstr(stdscr,4+graph_h+1,2,f"STATUS: {status} ({reason})",color)
        eff_arrow = trend_arrow(eff, avg_h and (h0/(h0+m0)*100 if (h0+m0) else eff))
        ratio_arrow = trend_arrow(mps, short_m if 'short_m' in locals() else avg_m)
        safe_addstr(
            stdscr,4+graph_h+2,2,
            f"HEALTH: {status} | EFF {eff:.1f}%{eff_arrow} (crit<{EFF_CRITICAL_THRESHOLD:.0f}) | MISS/HIT {ratio_text}{ratio_arrow} (crit≥{MISS_HIT_RATIO_CRITICAL:.2f})",
            color
        )
        if len(hits) >= 10 and len(miss) >= 10:
            short_h = sum(list(hits)[-10:]) / 10
            short_m = sum(list(miss)[-10:]) / 10
        else:
            short_h = avg_h
            short_m = avg_m
        safe_addstr(stdscr,graph_y+graph_h+3,2,f"10s AVG -> H:{short_h:.0f}/s  M:{short_m:.0f}/s  ΔMISS:{pct_change(short_m, avg_m):+.0f}% vs window",4)

        # -------- CONTAINERS --------
        y = graph_y+graph_h+5
        safe_addstr(stdscr,y,2,"CACHE NUMBERS",4)
        y += 1
        safe_addstr(stdscr,y,2,f"Total Hits:   {h0:,}")
        safe_addstr(stdscr,y,32,f"Total Misses: {m0:,}")
        y += 1
        safe_addstr(stdscr,y,2,f"Efficiency:   {eff:6.2f}%")
        safe_addstr(stdscr,y,32,f"Miss/Hit:     {ratio_text}")
        y += 1
        safe_addstr(stdscr,y,2,f"Peak Hit/s:   {max_h:>6}")
        safe_addstr(stdscr,y,32,f"Peak Miss/s:  {max_m:>6}")
        y += 2
        safe_addstr(stdscr,y,2,"CONTAINERS",4)
        y+=1

        if now - docker_last >= DOCKER_REFRESH_SECONDS:
            docker_cache, docker_state = docker(selected_containers)
            docker_last = now

        selection_label = f"{len(selected_containers)} selected" if selected_containers else "ALL (empty selection)"
        safe_addstr(stdscr, y, 2, f"Containers: {selection_label}", 4)
        y += 1
        safe_addstr(stdscr,y,32,f"DATA: SYSFS {'OK' if sysfs_ok else 'MISSING'} | DOCKER {docker_state}", 4)
        y += 1
        for name,cpu,mem in docker_cache:
            if y+1 >= maxy:
                break

            cpu_col = max(24, maxx // 3)
            mem_col = max(cpu_col + 20, (maxx * 2) // 3)
            cpu_room = max(0, mem_col - cpu_col - 10)
            mem_room = max(0, maxx - mem_col - 12)
            bar_cpu = "█" * (int((max(0.0, min(cpu, 100.0)) / 100) * cpu_room) if cpu_room else 0)
            bar_mem = "█" * (int((max(0.0, min(mem, 100.0)) / 100) * mem_room) if mem_room else 0)

            max_name_len = max(6, cpu_col - 4)
            disp_name = name if len(name) <= max_name_len else name[:max_name_len-1] + "…"
            safe_addstr(stdscr,y,2,disp_name)
            safe_addstr(stdscr,y,cpu_col,f"C {cpu:4.1f}% {bar_cpu}",2)
            safe_addstr(stdscr,y,mem_col,f"R {mem:4.1f}% {bar_mem}",3)

            y+=1

        if update_notice:
            safe_addstr(stdscr,maxy-2,2,update_notice,3)
        if config_notice:
            safe_addstr(stdscr,maxy-2,2,config_notice,3)
        safe_addstr(stdscr,maxy-1,2,"Q=quit  S=settings")

        stdscr.refresh()

        key = stdscr.getch()
        if key in [ord('q'),ord('Q')]:
            break
        if key in [ord('s'),ord('S')]:
            open_settings()
            docker_last = 0.0

        time.sleep(1)

def main():
    updated_from = os.environ.get("BCACHE_MONITOR_UPDATED_FROM")
    updated_to = os.environ.get("BCACHE_MONITOR_UPDATED_TO")
    if updated_from and updated_to:
        print_update_event(f"Update erfolgreich angewendet: {updated_from} -> {updated_to}")
        time.sleep(1)

    self_update_if_needed()
    curses.wrapper(init)

def init(stdscr):
    curses.start_color()
    curses.init_pair(1,curses.COLOR_RED,curses.COLOR_BLACK)
    curses.init_pair(2,curses.COLOR_GREEN,curses.COLOR_BLACK)
    curses.init_pair(3,curses.COLOR_YELLOW,curses.COLOR_BLACK)
    curses.init_pair(4,curses.COLOR_CYAN,curses.COLOR_BLACK)
    draw(stdscr)

if __name__=="__main__":
    main()
