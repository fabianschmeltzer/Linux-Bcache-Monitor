def normalize_version_string(value):
    if value is None:
        return ""
    token = str(value).strip()
    if token.lower().startswith("v"):
        token = token[1:]
    return token


def is_valid_version_string(value):
    token = normalize_version_string(value)
    if not token:
        return False
    parts = token.split('.')
    if not parts:
        return False
    return all(part.isdigit() for part in parts)


