def read(p):
    try:
        return open(p).read().strip()
    except (FileNotFoundError, PermissionError, OSError):
        return None

def parse_version(v):
    try:
        token = normalize_version_string(v)
        return tuple(int(part) for part in token.split("."))
    except:
        return (0,)

def read_remote_text(url):
    if not url:
        return ""
    try:
        with urllib.request.urlopen(url, timeout=3) as r:
            return r.read().decode("utf-8").strip()
    except:
        return ""

def read_remote_bytes(url):
    if not url:
        return b""
    try:
        with urllib.request.urlopen(url, timeout=3) as r:
            return r.read()
    except:
        return b""

def print_update_event(message):
    ts = time.strftime("%H:%M:%S")
    print(f"[bcache-monitor][{ts}] {message}", flush=True)

def self_update_if_needed():
    remote_version_raw = read_remote_text(VERSION_URL)
    remote_version = normalize_version_string(remote_version_raw)
    if not is_valid_version_string(remote_version):
        print_update_event(f"Update übersprungen: ungültige Remote-Version '{remote_version_raw}'")
        return False

    if parse_version(remote_version) <= parse_version(__version__):
        return False

    print_update_event(f"Update verfügbar: {__version__} -> {remote_version}")

    script_bytes = read_remote_bytes(SCRIPT_URL)
    if not script_bytes:
        print_update_event("Update abgebrochen: Script konnte nicht geladen werden")
        return False

    script_content = script_bytes.decode("utf-8", errors="replace")
    if not script_content.startswith("#!/usr/bin/env python3"):
        return False

    script_size = len(script_bytes)
    if script_size < MIN_SCRIPT_SIZE_BYTES or script_size > MAX_SCRIPT_SIZE_BYTES:
        print_update_event("Update abgebrochen: ungültige Scriptgröße")
        return False

    script_path = os.path.realpath(__file__)
    temp_path = f"{script_path}.tmp"

    try:
        current_mode = os.stat(script_path).st_mode & 0o777

        with open(temp_path, "w", encoding="utf-8") as dst:
            dst.write(script_content)
            dst.flush()
            os.fsync(dst.fileno())

        os.chmod(temp_path, current_mode)
        os.replace(temp_path, script_path)

        os.environ["BCACHE_MONITOR_UPDATED_FROM"] = __version__
        os.environ["BCACHE_MONITOR_UPDATED_TO"] = remote_version
        print_update_event(f"Aktualisiere auf {remote_version} und starte neu...")
        time.sleep(1)
        os.execv(sys.executable, [sys.executable, script_path] + sys.argv[1:])
    except Exception as exc:
        print_update_event(f"Update fehlgeschlagen: {exc}")
    finally:
        try:
            if os.path.exists(temp_path):
                os.remove(temp_path)
        except:
            pass

    return False

def parse_sysfs_size_bytes(raw_value):
    if raw_value is None:
        return None

    token = str(raw_value).strip()
    if not token:
        return None

    token = token.replace(" ", "")
    lower = token.lower()

    i = 0
    while i < len(lower) and (lower[i].isdigit() or lower[i] == "."):
        i += 1

    if i == 0:
        return None

    number = lower[:i]
    suffix = lower[i:]

    try:
        value = float(number)
    except:
        return None

    units = {
        "": 1,
        "b": 1,
        "k": 1024,
        "kb": 1024,
        "kib": 1024,
        "m": 1024 ** 2,
        "mb": 1024 ** 2,
        "mib": 1024 ** 2,
        "g": 1024 ** 3,
        "gb": 1024 ** 3,
        "gib": 1024 ** 3,
    }

    if suffix not in units:
        return None

    return int(value * units[suffix])


def format_dirty_value(dirty_bytes):
    if dirty_bytes is None:
        return "N/A"

    mib = dirty_bytes / (1024 ** 2)
    if mib < 1024:
        return f"{mib:.1f} MiB"

    gib = dirty_bytes / (1024 ** 3)
    return f"{gib:.1f} GiB"


def dirty_val():
    if not BCACHE:
        return None
    return parse_sysfs_size_bytes(read(f"{BCACHE}/dirty_data"))

def list_bcache_devices():
    candidates = []
    for path in sorted(glob.glob("/sys/block/*/bcache")):
        if os.path.isdir(path):
            device = os.path.basename(os.path.dirname(path))
            if device:
                candidates.append((device, path))
    return candidates


def resolve_bcache_device(config_device=""):
    candidates = list_bcache_devices()
    devices = [device for device, _ in candidates]
    device_map = {device: path for device, path in candidates}

    if not candidates:
        return {
            "device": None,
            "path": None,
            "source": "none",
            "devices": devices,
            "warning": "Kein bcache-Gerät gefunden (erwartet: /sys/block/*/bcache).",
        }

    env_device = os.environ.get("BCACHE_MONITOR_DEVICE", "").strip()
    config_device = (config_device or "").strip()

    if config_device:
        if config_device in device_map:
            return {"device": config_device, "path": device_map[config_device], "source": "config", "devices": devices, "warning": ""}
        first_device = devices[0]
        return {
            "device": first_device,
            "path": device_map[first_device],
            "source": "auto",
            "devices": devices,
            "warning": f"Gespeichertes Device '{config_device}' nicht gefunden; Auto-Fallback aktiv.",
        }

    if env_device and env_device in device_map:
        return {"device": env_device, "path": device_map[env_device], "source": "env", "devices": devices, "warning": ""}

    first_device = devices[0]
    warning = f"Env-Device '{env_device}' nicht gefunden; Auto-Fallback aktiv." if env_device else ""
    return {"device": first_device, "path": device_map[first_device], "source": "auto", "devices": devices, "warning": warning}


def default_config():
    return {
        "containers": list(DEFAULT_CONFIG["containers"]),
        "bcache_device": DEFAULT_CONFIG["bcache_device"],
    }


def _sanitize_config(raw):
    cfg = default_config()
    if not isinstance(raw, dict):
        return cfg

    containers = raw.get("containers")
    if isinstance(containers, list):
        cleaned = []
        seen = set()
        for item in containers:
            if not isinstance(item, str):
                continue
            name = item.strip()
            if not name or name in seen:
                continue
            seen.add(name)
            cleaned.append(name)
        cfg["containers"] = cleaned

    dev = raw.get("bcache_device")
    if isinstance(dev, str):
        cfg["bcache_device"] = dev.strip()

    return cfg


def load_config():
    try:
        with open(CONFIG_PATH, "r", encoding="utf-8") as src:
            return _sanitize_config(json.load(src)), ""
    except FileNotFoundError:
        cfg = default_config()
        ok, msg = save_config(cfg)
        return cfg, ("Config nicht gefunden; Defaults erstellt." if ok else f"Config fehlt ({msg})")
    except PermissionError:
        return default_config(), "Config nicht lesbar (Berechtigungen)."
    except json.JSONDecodeError:
        return default_config(), "Config defekt (JSON). Defaults genutzt."
    except OSError as exc:
        return default_config(), f"Config-Lesen fehlgeschlagen: {exc}"


def save_config(config):
    cfg = _sanitize_config(config)
    directory = os.path.dirname(CONFIG_PATH)
    temp_path = f"{CONFIG_PATH}.tmp"
    try:
        os.makedirs(directory, exist_ok=True)
        with open(temp_path, "w", encoding="utf-8") as dst:
            json.dump(cfg, dst, indent=2, ensure_ascii=False)
            dst.write("\n")
            dst.flush()
            os.fsync(dst.fileno())
        os.replace(temp_path, CONFIG_PATH)
        return True, ""
    except PermissionError:
        return False, "Keine Schreibberechtigung für Config."
    except OSError as exc:
        return False, str(exc)
    finally:
        try:
            if os.path.exists(temp_path):
                os.remove(temp_path)
        except OSError:
            pass


def _run_command(command, timeout=2.0):
    try:
        cp = subprocess.run(command, capture_output=True, text=True, timeout=timeout, check=False)
        if cp.returncode != 0:
            return {"ok": False, "status": f"ERR:{cp.returncode}", "stdout": cp.stdout, "stderr": cp.stderr}
        return {"ok": True, "status": "OK", "stdout": cp.stdout, "stderr": cp.stderr}
    except subprocess.TimeoutExpired:
        return {"ok": False, "status": "TIMEOUT", "stdout": "", "stderr": ""}
    except FileNotFoundError:
        return {"ok": False, "status": "NOT INSTALLED", "stdout": "", "stderr": ""}


def list_running_containers():
    result = _run_command(["docker", "ps", "--format", "{{.Names}}"], timeout=2.0)
    if not result["ok"]:
        return [], result["status"]
    names = [line.strip() for line in result["stdout"].splitlines() if line.strip()]
    return names, result["status"]


def _normalize_container_name(name):
    return str(name or "").strip().lstrip("/")


def _parse_stats_output(stdout, selected=None):
    entries = []
    for line in stdout.splitlines():
        parts = line.split("|")
        if len(parts) != 3:
            continue
        name, cpu_raw, mem_raw = parts
        normalized = _normalize_container_name(name)
        if selected and normalized not in selected:
            continue

        cpu = _parse_percent(cpu_raw)
        mem = _parse_percent(mem_raw)
        if cpu is None or mem is None:
            continue
        entries.append((normalized or name, cpu, mem))
    return entries


def list_container_stats(selected_containers):
    selected = sorted({_normalize_container_name(name) for name in (selected_containers or []) if _normalize_container_name(name)})
    format_args = ["--no-stream", "--format", "{{.Name}}|{{.CPUPerc}}|{{.MemPerc}}"]

    command = ["docker", "stats", *format_args]
    if selected:
        command.extend(selected)

    result = _run_command(command, timeout=2.5)
    if not result["ok"]:
        return [], result["status"]

    selected_filter = set(selected) if selected else None
    res = _parse_stats_output(result["stdout"], selected=selected_filter)

    if res:
        return res, "OK"

    return [], ("NO CONTAINERS" if selected else "ALL (none running)")

STATS_TOTAL_PATH = None


def _discover_stats_total_path():
    for root, dirs, _ in os.walk("/sys/fs/bcache"):
        if "stats_total" in dirs:
            return os.path.join(root, "stats_total")
    return ""


def stats():
    global STATS_TOTAL_PATH
    if STATS_TOTAL_PATH is None:
        STATS_TOTAL_PATH = _discover_stats_total_path()

    if not STATS_TOTAL_PATH:
        return None, None

    h = read(f"{STATS_TOTAL_PATH}/cache_hits")
    m = read(f"{STATS_TOTAL_PATH}/cache_misses")

    if h is None or m is None:
        STATS_TOTAL_PATH = None
        return None, None

    return int(h), int(m)

def _parse_percent(raw):
    if raw is None:
        return None
    token = str(raw).strip().replace("%", "").replace(",", ".")
    if not token:
        return None
    try:
        return float(token)
    except ValueError:
        return None


