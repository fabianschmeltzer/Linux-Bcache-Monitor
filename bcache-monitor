#!/usr/bin/env python3
import curses, time, subprocess, os, sys, urllib.request
from collections import deque

__version__ = "0.1.1"

# URLs can be overridden for your publish target, e.g. GitHub raw links.
VERSION_URL = os.environ.get("BCACHE_MONITOR_VERSION_URL", "")
SCRIPT_URL = os.environ.get("BCACHE_MONITOR_SCRIPT_URL", "")
BCACHE="/sys/block/bcache0/bcache"
HISTORY=200
TREND_WINDOW=30
EFF_WARN_THRESHOLD=70.0
EFF_CRITICAL_THRESHOLD=50.0
MISS_HIT_RATIO_WARN=0.75
MISS_HIT_RATIO_CRITICAL=1.10
MISS_TREND_WARN=1.20
MISS_TREND_CRITICAL=1.50

TARGETS = {
    "nextcloud_app",
    "immich-server",
    "immich-machine-learning",
    "piwigo"
}

# ---------- SAFE DRAW ----------

def safe_addstr(stdscr,y,x,text,color=0):
    maxy,maxx = stdscr.getmaxyx()
    if 0 <= y < maxy and 0 <= x < maxx:
        try:
            stdscr.addstr(y,x,text[:maxx-x-1],curses.color_pair(color))
        except:
            pass

# ---------- HELPERS ----------

def read(p):
    try: return open(p).read().strip()
    except: return "0"

def parse_version(v):
    try:
        return tuple(int(part) for part in v.strip().split("."))
    except:
        return (0,)

def read_remote_text(url):
    if not url:
        return ""
    try:
        with urllib.request.urlopen(url, timeout=3) as r:
            return r.read().decode("utf-8").strip()
    except:
        return ""

def self_update_if_needed():
    remote_version = read_remote_text(VERSION_URL)
    if not remote_version:
        return False

    if parse_version(remote_version) <= parse_version(__version__):
        return False

    print(f"[bcache-monitor] Update verfügbar: {__version__} -> {remote_version}", flush=True)

    script_content = read_remote_text(SCRIPT_URL)
    if not script_content.startswith("#!/usr/bin/env python3"):
        return False

    script_path = os.path.realpath(__file__)
    backup_path = f"{script_path}.bak"

    try:
        with open(script_path, "r", encoding="utf-8") as src:
            old_content = src.read()

        with open(backup_path, "w", encoding="utf-8") as backup:
            backup.write(old_content)

        with open(script_path, "w", encoding="utf-8") as dst:
            dst.write(script_content)

        os.chmod(script_path, 0o755)
        os.environ["BCACHE_MONITOR_UPDATED_FROM"] = __version__
        os.environ["BCACHE_MONITOR_UPDATED_TO"] = remote_version
        print(f"[bcache-monitor] Aktualisiere auf {remote_version} und starte neu...", flush=True)
        os.execv(script_path, [script_path] + sys.argv[1:])
    except:
        try:
            if os.path.exists(backup_path):
                with open(backup_path, "r", encoding="utf-8") as backup:
                    restore = backup.read()
                with open(script_path, "w", encoding="utf-8") as dst:
                    dst.write(restore)
        except:
            pass
    finally:
        try:
            if os.path.exists(backup_path):
                os.remove(backup_path)
        except:
            pass

    return False

def parse_sysfs_size_bytes(raw_value):
    if raw_value is None:
        return None

    token = str(raw_value).strip()
    if not token:
        return None

    token = token.replace(" ", "")
    lower = token.lower()

    i = 0
    while i < len(lower) and (lower[i].isdigit() or lower[i] == "."):
        i += 1

    if i == 0:
        return None

    number = lower[:i]
    suffix = lower[i:]

    try:
        value = float(number)
    except:
        return None

    units = {
        "": 1,
        "b": 1,
        "k": 1024,
        "kb": 1024,
        "kib": 1024,
        "m": 1024 ** 2,
        "mb": 1024 ** 2,
        "mib": 1024 ** 2,
        "g": 1024 ** 3,
        "gb": 1024 ** 3,
        "gib": 1024 ** 3,
    }

    if suffix not in units:
        return None

    return int(value * units[suffix])


def format_dirty_value(dirty_bytes):
    if dirty_bytes is None:
        return "N/A"

    mib = dirty_bytes / (1024 ** 2)
    if mib < 1024:
        return f"{mib:.1f} MiB"

    gib = dirty_bytes / (1024 ** 3)
    return f"{gib:.1f} GiB"


def dirty_val():
    return parse_sysfs_size_bytes(read(f"{BCACHE}/dirty_data"))

def stats():
    for r,d,_ in os.walk("/sys/fs/bcache"):
        if "stats_total" in d:
            p=os.path.join(r,"stats_total")
            return int(read(f"{p}/cache_hits")),int(read(f"{p}/cache_misses"))
    return 0,0

def docker():
    try:
        raw = subprocess.getoutput(
            "docker stats --no-stream --format '{{.Name}}|{{.CPUPerc}}|{{.MemPerc}}'"
        ).split("\n")

        res=[]
        for l in raw:
            p=l.split("|")
            if len(p)!=3: continue
            n,c,m=p
            if n not in TARGETS: continue
            res.append((n,float(c.replace("%","")),float(m.replace("%",""))))
        return res
    except:
        return []

# ---------- GRAPH (AREA STYLE) ----------



def status_from_metrics(eff, hps, mps, miss_window):
    ratio = (mps / hps) if hps > 0 else (float("inf") if mps > 0 else 0.0)

    trend = 1.0
    if len(miss_window) >= 6:
        half = len(miss_window) // 2
        first_avg = sum(list(miss_window)[:half]) / max(half, 1)
        second_avg = sum(list(miss_window)[half:]) / max(len(miss_window) - half, 1)
        if first_avg <= 0:
            trend = float("inf") if second_avg > 0 else 1.0
        else:
            trend = second_avg / first_avg

    status = "OK"
    color = 2
    reasons = []

    if eff < EFF_CRITICAL_THRESHOLD:
        status = "CRITICAL"
        color = 1
        reasons.append(f"eff {eff:.0f}%")
    elif eff < EFF_WARN_THRESHOLD:
        if status != "CRITICAL":
            status = "WARN"
            color = 3
        reasons.append(f"eff {eff:.0f}%")

    if ratio >= MISS_HIT_RATIO_CRITICAL:
        status = "CRITICAL"
        color = 1
        reasons.append(f"miss/hit {ratio:.2f}")
    elif ratio >= MISS_HIT_RATIO_WARN and status == "OK":
        status = "WARN"
        color = 3
        reasons.append(f"miss/hit {ratio:.2f}")

    if trend >= MISS_TREND_CRITICAL:
        status = "CRITICAL"
        color = 1
        reasons.append("miss trend ↑")
    elif trend >= MISS_TREND_WARN and status == "OK":
        status = "WARN"
        color = 3
        reasons.append("miss trend ↑")

    if not reasons:
        reasons.append("stable")

    return status, color, ", ".join(reasons)
def draw_area_graph(stdscr,data,y,x,w,h,color):
    if len(data)<2: return
    d=list(data)[-w:]
    maxv=max(d) if max(d)>0 else 1

    for i,val in enumerate(d):
        height=int((val/maxv)*(h-1))
        for j in range(height):
            safe_addstr(stdscr,y+h-j,x+i,"█",color)
# ---------- GRAPH ----------

def draw_line_graph(stdscr, data, y, x, w, h, color, maxv):
    if len(data) < 2 or w < 2 or h < 2:
        return

    d = list(data)[-w:]
    points = []
    for i, val in enumerate(d):
        row = y + h - 1 - int((max(0, val) / maxv) * (h - 1))
        points.append((row, x + i))

    prev_row, prev_col = points[0]
    safe_addstr(stdscr, prev_row, prev_col, "•", color)

    for row, col in points[1:]:
        safe_addstr(stdscr, row, col, "•", color)
        if row == prev_row:
            for c in range(min(prev_col, col) + 1, max(prev_col, col)):
                safe_addstr(stdscr, row, c, "─", color)
        else:
            step = 1 if row > prev_row else -1
            cur = prev_row
            while cur != row:
                cur += step
                safe_addstr(stdscr, cur, prev_col, "│", color)
        prev_row, prev_col = row, col

def draw_y_markers(stdscr, y, x, h, maxv):
    ticks = [
        (0, maxv),
        (h // 2, maxv / 2),
        (h - 1, 0),
    ]
    for off, value in ticks:
        r = y + off
        safe_addstr(stdscr, r, x, "┤", 4)
        safe_addstr(stdscr, r, x - 7, f"{int(value):>6}", 4)

# ---------- MAIN ----------

def draw(stdscr):
    curses.curs_set(0)
    stdscr.nodelay(True)

    update_notice = ""
    updated_from = os.environ.get("BCACHE_MONITOR_UPDATED_FROM", "").strip()
    updated_to = os.environ.get("BCACHE_MONITOR_UPDATED_TO", "").strip()
    if updated_from and updated_to:
        update_notice = f"UPDATED: {updated_from} -> {updated_to}"

    hits=deque(maxlen=HISTORY)
    miss=deque(maxlen=HISTORY)
    miss_trend=deque(maxlen=TREND_WINDOW)

    ph,pm=stats()
    pt=time.time()

    while True:
        stdscr.erase()
        maxy,maxx=stdscr.getmaxyx()

        if maxy < 12 or maxx < 48:
            safe_addstr(stdscr, 0, 0, "BCACHE OBS")
            safe_addstr(stdscr, 1, 0, "Terminal too small")
            safe_addstr(stdscr, 2, 0, f"H:{hps if 'hps' in locals() else 0} M:{mps if 'mps' in locals() else 0}")
            safe_addstr(stdscr, 3, 0, "Q=quit")
            stdscr.refresh()
            if stdscr.getch() in [ord('q'),ord('Q')]:
                break
            time.sleep(1)
            continue

        # DATA
        h0,m0=stats()
        now=time.time()
        dt=max(now-pt,0.5)

        hps=int((h0-ph)/dt)
        mps=int((m0-pm)/dt)

        ph,pm,pt=h0,m0,now

        hits.append(hps)
        miss.append(mps)
        miss_trend.append(mps)

        eff=h0/(h0+m0)*100 if (h0+m0) else 0
        dirty_bytes=dirty_val()
        dirty_display=format_dirty_value(dirty_bytes)

        # -------- HEADER --------
        safe_addstr(stdscr,0,2,f"BCACHE OBSERVABILITY v{__version__}",4)

        # -------- TOP BAR --------
        safe_addstr(stdscr,2,2,f"EFF {eff:.1f}% | DIRTY {dirty_display} | H:{hps} M:{mps}")

        # -------- GRAPH --------
        graph_h = max(6, maxy//3)
        graph_w = max(20, maxx-14)
        graph_y = 4
        graph_x = 10
        maxv = max(max(hits) if hits else 0, max(miss) if miss else 0, 1)

        draw_y_markers(stdscr, graph_y, graph_x - 1, graph_h, maxv)
        draw_line_graph(stdscr, miss, graph_y, graph_x, graph_w, graph_h, 1, maxv)
        draw_line_graph(stdscr, hits, graph_y, graph_x, graph_w, graph_h, 2, maxv)
        safe_addstr(stdscr, graph_y + graph_h, graph_x, "└" + ("─" * (graph_w - 1)), 4)

        avg_h = (sum(hits) / len(hits)) if hits else 0
        avg_m = (sum(miss) / len(miss)) if miss else 0
        max_h = max(hits) if hits else 0
        max_m = max(miss) if miss else 0
        safe_addstr(stdscr, graph_y, graph_x + 2, f"H {hps}/{avg_h:.0f}/{max_h}", 2)
        safe_addstr(stdscr, graph_y + 1, graph_x + 2, f"M {mps}/{avg_m:.0f}/{max_m}", 1)
        safe_addstr(stdscr, graph_y + graph_h + 1, graph_x, f"last {HISTORY}s", 4)

        # -------- STATUS --------
        status,color,reason=status_from_metrics(eff,hps,mps,miss_trend)
        safe_addstr(stdscr,4+graph_h+1,2,f"STATUS: {status} ({reason})",color)
        status="OK"
        color=2
        if mps > hps:
            status="HDD LOAD"
            color=1

        safe_addstr(stdscr,graph_y+graph_h+2,2,f"STATUS: {status}",color)

        # -------- CONTAINERS --------
        y = graph_y+graph_h+4
        safe_addstr(stdscr,y,2,"CONTAINERS",4)
        y+=1

        for name,cpu,mem in docker():
            if y+1 >= maxy:
                break

            bar_cpu = "█"*int(cpu/5)
            bar_mem = "█"*int(mem/5)

            safe_addstr(stdscr,y,2,f"{name}")
            safe_addstr(stdscr,y,30,f"C {cpu:4.1f}% {bar_cpu}",2)
            safe_addstr(stdscr,y,55,f"R {mem:4.1f}% {bar_mem}",3)

            y+=1

        if update_notice:
            safe_addstr(stdscr,maxy-2,2,update_notice,3)
        safe_addstr(stdscr,maxy-1,2,"Q=quit")

        stdscr.refresh()

        if stdscr.getch() in [ord('q'),ord('Q')]:
            break

        time.sleep(1)

def main():
    self_update_if_needed()
    curses.wrapper(init)

def init(stdscr):
    curses.start_color()
    curses.init_pair(1,curses.COLOR_RED,curses.COLOR_BLACK)
    curses.init_pair(2,curses.COLOR_GREEN,curses.COLOR_BLACK)
    curses.init_pair(3,curses.COLOR_YELLOW,curses.COLOR_BLACK)
    curses.init_pair(4,curses.COLOR_CYAN,curses.COLOR_BLACK)
    draw(stdscr)

if __name__=="__main__":
    main()
